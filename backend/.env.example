# Flask core
# Generate a random SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(16))"
SECRET_KEY=your-random-secret-key-here

FLASK_ENV=development

# Database (leave empty for development to use the default path)
# For production: DATABASE_URL=postgresql://user:pass@host/db
DATABASE_URL=

# Brevo REST API (for email OTP delivery)
# IMPORTANT: Use the REST API key (from api.brevo.com/v3), NOT the SMTP key.
# smtp-relay.brevo.com is NOT on PythonAnywhere's free-tier whitelist.
# Get your API key at: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your-brevo-rest-api-key-here

# Brevo sender configuration
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=2FA Platform

# Twilio SMS credentials (for SMS OTP delivery)
# Get credentials at: https://console.twilio.com
# Note: Twilio trial accounts can only send to verified phone numbers.
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Auth configuration
# OTP expiry time in minutes (5 minutes = 300 seconds)
OTP_EXPIRY_MINUTES=5

# Maximum failed login attempts before account lockout
MAX_LOGIN_ATTEMPTS=5

# Session expiry time in minutes
SESSION_EXPIRY_MINUTES=30

# TOTP encryption key (Fernet)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOTP_ENCRYPTION_KEY=your-fernet-encryption-key-here

# CORS — set to your Netlify URL in production
# Local development: http://localhost:5173
# Production example: https://bhanu-2fa.netlify.app
FRONTEND_URL=http://localhost:5173
